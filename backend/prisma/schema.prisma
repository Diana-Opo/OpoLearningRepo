generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  agent
  manager
  admin
}

enum UserStatus {
  approved
  pending
  rejected
}


enum TicketStatus {
  open
  in_progress
  resolved
  closed
  archived
}

enum Priority {
  low
  medium
  high
  urgent
}

enum IssueStatus {
  investigating
  identified
  monitoring
  resolved
  archived
}

enum AgentStatus {
  online
  busy
  away
  offline
  archived
}

enum Shift {
  day
  night
}

// ─── Models ──────────────────────────────────────────────

model User {
  id                Int              @id @default(autoincrement())
  name              String
  email             String           @unique
  passwordHash      String?
  role              UserRole         @default(agent)
  status            UserStatus       @default(pending)
  avatarData        String?          @db.Text
  createdAt         DateTime         @default(now())
  permissionGroupId String?
  permissionGroup   PermissionGroup? @relation(fields: [permissionGroupId], references: [id], onDelete: SetNull)

  reportedIssues  PlatformIssue[]      @relation("ReportedByUser")
  assignedIssues  PlatformIssue[]      @relation("AssignedToUser")
  resetTokens     PasswordResetToken[]

  @@map("users")
}

model PermissionGroup {
  id        String   @id @default(cuid())
  name      String   @unique
  isSystem  Boolean  @default(false)
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  viewDashboard Boolean @default(false)
  viewLivechats Boolean @default(false)
  viewTickets   Boolean @default(false)
  viewIssues    Boolean @default(false)
  viewAgents    Boolean @default(false)
  viewReports   Boolean @default(false)

  ticketsCreate Boolean @default(false)
  ticketsEdit   Boolean @default(false)
  ticketsDelete Boolean @default(false)
  ticketsExport Boolean @default(false)

  issuesCreate  Boolean @default(false)
  issuesEdit    Boolean @default(false)
  issuesDelete  Boolean @default(false)
  issuesExport  Boolean @default(false)

  agentsCreate  Boolean @default(false)
  agentsEdit    Boolean @default(false)
  agentsArchive Boolean @default(false)
  agentsExport  Boolean @default(false)

  reportsExport Boolean @default(false)

  users User[]

  @@map("permission_groups")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model Ticket {
  id          Int          @id @default(autoincrement())
  subject     String
  clientEmail String
  description String?      @db.Text
  status      TicketStatus @default(open)
  priority    Priority     @default(medium)
  assignedTo  Int?
  agent       Agent?       @relation(fields: [assignedTo], references: [id])
  createdAt   DateTime     @default(now())

  comments    TicketComment[]

  @@map("tickets")
}

model TicketComment {
  id         Int      @id @default(autoincrement())
  ticketId   Int
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorName String
  role       String   @default("reply")
  text       String   @db.Text
  createdAt  DateTime @default(now())

  @@map("ticket_comments")
}

model PlatformIssue {
  id          Int         @id @default(autoincrement())
  title       String
  platform    String
  priority    Priority    @default(medium)
  status      IssueStatus @default(investigating)
  summary     String
  description String?     @db.Text
  reportedBy  Int?
  reporter    User?       @relation("ReportedByUser", fields: [reportedBy], references: [id])
  assignedTo  Int?
  assignee    User?       @relation("AssignedToUser", fields: [assignedTo], references: [id])
  createdAt   DateTime    @default(now())
  modifiedAt  DateTime    @updatedAt

  comments    PlatformIssueComment[]

  @@map("platform_issues")
}

model PlatformIssueComment {
  id         Int           @id @default(autoincrement())
  issueId    Int
  issue      PlatformIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  authorName String
  text       String        @db.Text
  createdAt  DateTime      @default(now())

  @@map("platform_issue_comments")
}

model Agent {
  id         Int         @id @default(autoincrement())
  name       String
  email      String      @unique
  shift      Shift       @default(day)
  status     AgentStatus @default(offline)
  createdAt  DateTime    @default(now())
  modifiedAt DateTime    @updatedAt

  assignedTickets Ticket[]

  @@map("agents")
}
